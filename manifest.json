{
  "manifest_version": 3,
  "name": "Qshot",
  "version": "0.1.0",
  "description": "在一个扩展页面中以多卡片 iframe 形式并排展示多个 AI 站点。",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "activeTab",
    "storage",
    "tabs",
    "declarativeNetRequest"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; frame-src *; img-src 'self' chrome-extension: data: blob:;"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Qshot",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_popup": "popup/popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "config/baseConfig.js",
        "iframe/inject.js"
      ],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "iframe/*",
        "config/*",
        "popup/*"
      ],
      "matches": [
        "<all_urls>",
        "chrome-extension://*/*"
      ]
    }
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "iframe_rules",
        "enabled": true,
        "path": "config/rules.json"
      }
    ]
  }
}
